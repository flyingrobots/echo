# Legacy compatibility shim.
#
# The canonical repository hooks live in `.githooks/` and are installed with
# `make hooks`. This script remains as a minimal manual fallback for developers
# who explicitly invoke `scripts/hooks/*` outside the configured git hook path.
set -euo pipefail

echo "pre-push: running cargo test (workspace, skip doc-tests)..."
cargo test --workspace --tests
echo "pre-push: all tests passed."
